<Application x:Class="AtlasERP.Presentation.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AtlasERP.Presentation.WPF.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme dictionary is swapped at runtime by ThemeManager; Generic.xaml holds
                     shared control styles that don't change between Light/Dark. -->
                <ResourceDictionary Source="Themes/Generic.xaml" />
                <ResourceDictionary Source="Themes/Light.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <conv:BoolToVisibleConverter x:Key="BoolToVisibleConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
