<UserControl x:Class="AtlasERP.Presentation.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" MaxWidth="480" HorizontalAlignment="Left">
            <TextBlock Text="Company settings" Style="{StaticResource Text.Heading1}" />
            <TextBlock Text="Rename this brand and upload its logo — the logo's colors carry over to printed documents"
                       Style="{StaticResource Text.Subtitle}"
                       TextWrapping="Wrap"
                       Margin="0,2,0,24" />

            <Border Style="{StaticResource Panel.Card}">
                <StackPanel>
                    <TextBlock Text="Logo" Style="{StaticResource Text.Label}" />
                    <Border Width="120" Height="120"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="{DynamicResource Brush.Background.Hover}"
                            Margin="0,0,0,8">
                        <Image Source="{Binding LogoPath, Converter={StaticResource PathToImageSourceConverter}}"
                               Stretch="Uniform"
                               Margin="8" />
                    </Border>
                    <Button Content="Browse for logo..." Command="{Binding BrowseLogoCommand}" HorizontalAlignment="Left" Margin="0,0,0,20" />

                    <TextBlock Text="Display name *" Style="{StaticResource Text.Label}" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="Legal name *" Style="{StaticResource Text.Label}" />
                    <TextBox Text="{Binding LegalName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="Brand color" Style="{StaticResource Text.Label}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="32" Height="32" CornerRadius="7"
                                Background="{Binding BrandColorHex, Converter={StaticResource HexToBrushConverter}}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                Margin="0,0,10,0" />
                        <TextBox Text="{Binding BrandColorHex, UpdateSourceTrigger=PropertyChanged}" Width="140" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource Brush.Error}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource Brush.Success}"
                               Margin="0,0,0,8"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsedConverter}}" />

                    <Button Content="Save" Style="{StaticResource Button.Primary}" Command="{Binding SaveCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
