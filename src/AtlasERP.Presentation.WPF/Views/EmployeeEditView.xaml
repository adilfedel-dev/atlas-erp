<Window x:Class="AtlasERP.Presentation.WPF.Views.EmployeeEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="560" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background.Window}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource Brush.Text.Primary}"
                   Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Employee code *" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EmployeeCode, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="First name *" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Last name *" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Gender" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding GenderOptions}" SelectedItem="{Binding Gender}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Date of birth" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <DatePicker SelectedDate="{Binding DateOfBirth}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="National ID" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Personal email" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding PersonalEmail, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Job title *" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding JobTitle, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Hire date" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <DatePicker SelectedDate="{Binding HireDate}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Employment status" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding EmploymentStatusOptions}" SelectedItem="{Binding EmploymentStatus}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Base salary" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding BaseSalary, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Work email" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding WorkEmail, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Phone number" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                        <TextBlock Text="Bank name" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding BankName, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Address" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                <TextBlock Text="Bank account number" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding BankAccountNumber, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,12" />

                <TextBlock Text="Notes" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Height="60" Padding="6" Margin="0,0,0,12" />
            </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Brush.Error}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="14,8" Margin="0,0,8,0" />
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Padding="14,8"
                    Background="{DynamicResource Brush.Accent}"
                    Foreground="White"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</Window>
