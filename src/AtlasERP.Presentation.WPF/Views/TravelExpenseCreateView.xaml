<Window x:Class="AtlasERP.Presentation.WPF.Views.TravelExpenseCreateView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New travel expense report"
        Width="420" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Background.Window}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="New travel expense report" Style="{StaticResource Text.Heading2}" Margin="0,0,0,16" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="Employee *" Style="{StaticResource Text.Label}" />
            <ComboBox ItemsSource="{Binding EmployeeOptions}"
                      DisplayMemberPath="DisplayName"
                      SelectedItem="{Binding SelectedEmployee}"
                      Margin="0,0,0,12" />

            <TextBlock Text="Destination *" Style="{StaticResource Text.Label}" />
            <TextBox Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

            <TextBlock Text="Purpose *" Style="{StaticResource Text.Label}" />
            <TextBox Text="{Binding Purpose, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

            <TextBlock Text="Departure date" Style="{StaticResource Text.Label}" />
            <DatePicker SelectedDate="{Binding DepartureDate}" Margin="0,0,0,12" />

            <TextBlock Text="Return date" Style="{StaticResource Text.Label}" />
            <DatePicker SelectedDate="{Binding ReturnDate}" Margin="0,0,0,12" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource Brush.Error}"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,8,0" />
            <Button Content="Create" Style="{StaticResource Button.Primary}" Command="{Binding ConfirmCommand}" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
