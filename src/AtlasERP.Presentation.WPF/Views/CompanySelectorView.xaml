<Window x:Class="AtlasERP.Presentation.WPF.Views.CompanySelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AtlasERP — Select company"
        Width="440" Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Background.Window}">
    <Grid>
        <Border Width="360" Style="{StaticResource Panel.Card}" Padding="32"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Choose a company" Style="{StaticResource Text.Heading1}" HorizontalAlignment="Center" />
                <TextBlock Text="This account has access to more than one company"
                           Style="{StaticResource Text.Subtitle}"
                           Margin="0,4,0,20"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />

                <ListBox ItemsSource="{Binding Companies}"
                         SelectedItem="{Binding SelectedCompany}"
                         DisplayMemberPath="Name"
                         Height="180"
                         Margin="0,0,0,16" />

                <Button Content="Continue"
                        Style="{StaticResource Button.Primary}"
                        Command="{Binding ConfirmSelectionCommand}"
                        IsDefault="True"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
