<Window x:Class="AtlasERP.Presentation.WPF.Views.TravelExpenseDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Travel expense report"
        Width="920" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background.Window}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{Binding EmployeeName}" Style="{StaticResource Text.Heading1}" />
                <TextBlock Style="{StaticResource Text.Subtitle}">
                    <Run Text="{Binding Destination, Mode=OneWay}" />
                    <Run Text=" — " />
                    <Run Text="{Binding Status, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Reject" Command="{Binding RejectCommand}" Margin="0,0,8,0" />
                <Button Content="Submit" Command="{Binding SubmitCommand}" Margin="0,0,8,0" />
                <Button Content="Print" Style="{StaticResource Button.Primary}" Command="{Binding PrintCommand}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Brush.Error}"
                   Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Expenses" Style="{StaticResource Text.Heading2}" Margin="0,0,0,8" />
                <Border Style="{StaticResource Panel.Card}" Padding="0" Height="240" Margin="0,0,0,8">
                    <DataGrid ItemsSource="{Binding LineItems}"
                              SelectedItem="{Binding SelectedLineItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100" />
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <Button Content="Remove selected expense" Command="{Binding RemoveLineItemCommand}" Margin="0,0,0,16" />

                <TextBlock Text="Add expense" Style="{StaticResource Text.Heading2}" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Date" Style="{StaticResource Text.Label}" />
                        <DatePicker SelectedDate="{Binding NewLineItemDate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Category" Style="{StaticResource Text.Label}" />
                        <ComboBox ItemsSource="{Binding CategoryOptions}" SelectedItem="{Binding NewLineItemCategory}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Description" Style="{StaticResource Text.Label}" />
                        <TextBox Text="{Binding NewLineItemDescription, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Amount" Style="{StaticResource Text.Label}" />
                        <TextBox Text="{Binding NewLineItemAmount, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <Button Grid.Column="8" Content="Add" Style="{StaticResource Button.Primary}" Command="{Binding AddLineItemCommand}" VerticalAlignment="Bottom" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource Panel.Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Total" Style="{StaticResource Text.Caption}" />
                        <TextBlock Text="{Binding Total, StringFormat=C}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text.Primary}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel.Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Owner approval" Style="{StaticResource Text.Heading2}" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding OwnerApproverName}" Visibility="{Binding IsOwnerApproved, Converter={StaticResource BoolToVisibleConverter}}" />
                        <TextBlock Text="{Binding OwnerApprovedAtUtc}" Style="{StaticResource Text.Caption}" Visibility="{Binding IsOwnerApproved, Converter={StaticResource BoolToVisibleConverter}}" Margin="0,0,0,8" />
                        <Button Content="Sign as owner" Command="{Binding ApproveAsOwnerCommand}"
                                Visibility="{Binding IsOwnerApproved, Converter={StaticResource BoolToVisibleConverter}, ConverterParameter=Invert}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel.Card}">
                    <StackPanel>
                        <TextBlock Text="Accountant approval" Style="{StaticResource Text.Heading2}" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding AccountantApproverName}" Visibility="{Binding IsAccountantApproved, Converter={StaticResource BoolToVisibleConverter}}" />
                        <TextBlock Text="{Binding AccountantApprovedAtUtc}" Style="{StaticResource Text.Caption}" Visibility="{Binding IsAccountantApproved, Converter={StaticResource BoolToVisibleConverter}}" Margin="0,0,0,8" />
                        <Button Content="Sign as accountant" Command="{Binding ApproveAsAccountantCommand}"
                                Visibility="{Binding IsAccountantApproved, Converter={StaticResource BoolToVisibleConverter}, ConverterParameter=Invert}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
