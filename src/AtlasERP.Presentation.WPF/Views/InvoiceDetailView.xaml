<Window x:Class="AtlasERP.Presentation.WPF.Views.InvoiceDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invoice"
        Width="960" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background.Window}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{Binding InvoiceNumber}" Style="{StaticResource Text.Heading1}" />
                <TextBlock Text="{Binding CustomerName}" Style="{StaticResource Text.Subtitle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}" Width="120" Margin="0,0,8,0" />
                <Button Content="Update status" Command="{Binding UpdateStatusCommand}" Margin="0,0,8,0" />
                <Button Content="Print" Style="{StaticResource Button.Primary}" Command="{Binding PrintCommand}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Brush.Error}"
                   Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Line items" Style="{StaticResource Text.Heading2}" Margin="0,0,0,8" />
                <Border Style="{StaticResource Panel.Card}" Padding="0" Height="200" Margin="0,0,0,8">
                    <DataGrid ItemsSource="{Binding LineItems}"
                              SelectedItem="{Binding SelectedLineItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60" />
                            <DataGridTextColumn Header="Unit price" Binding="{Binding UnitPrice, StringFormat=C}" Width="90" />
                            <DataGridTextColumn Header="Total" Binding="{Binding LineTotal, StringFormat=C}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <Button Content="Remove selected line item" Command="{Binding RemoveLineItemCommand}" Margin="0,0,0,16" />

                <TextBlock Text="Add line item" Style="{StaticResource Text.Heading2}" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Description" Style="{StaticResource Text.Label}" />
                        <TextBox Text="{Binding NewLineItemDescription, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Qty" Style="{StaticResource Text.Label}" />
                        <TextBox Text="{Binding NewLineItemQuantity, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Unit price" Style="{StaticResource Text.Label}" />
                        <TextBox Text="{Binding NewLineItemUnitPrice, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <Button Grid.Column="6" Content="Add" Style="{StaticResource Button.Primary}" Command="{Binding AddLineItemCommand}" VerticalAlignment="Bottom" />
                </Grid>

                <TextBlock Text="Payments" Style="{StaticResource Text.Heading2}" Margin="0,20,0,8" />
                <Border Style="{StaticResource Panel.Card}" Padding="0" Height="140" Margin="0,0,0,8">
                    <DataGrid ItemsSource="{Binding Receipts}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding ReceivedDate, StringFormat=d}" Width="100" />
                            <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod}" Width="120" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Amount" Style="{StaticResource Text.Label}" />
                        <TextBox Text="{Binding NewReceiptAmount, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Date" Style="{StaticResource Text.Label}" />
                        <DatePicker SelectedDate="{Binding NewReceiptDate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Method" Style="{StaticResource Text.Label}" />
                        <ComboBox ItemsSource="{Binding PaymentMethodOptions}" SelectedItem="{Binding NewReceiptMethod}" />
                    </StackPanel>
                </Grid>
                <Button Content="Record payment" Style="{StaticResource Button.Primary}" Command="{Binding RecordReceiptCommand}" Margin="0,8,0,0" HorizontalAlignment="Left" />
            </StackPanel>

            <Border Grid.Column="2" Style="{StaticResource Panel.Card}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Summary" Style="{StaticResource Text.Heading2}" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Subtotal" Style="{StaticResource Text.Subtitle}" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding Subtotal, StringFormat=C}" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Tax" Style="{StaticResource Text.Subtitle}" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding TaxAmount, StringFormat=C}" HorizontalAlignment="Right" />
                    </Grid>
                    <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0" Margin="0,4,0,8" />
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Total" FontWeight="Bold" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding Total, StringFormat=C}" FontWeight="Bold" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Paid" Style="{StaticResource Text.Subtitle}" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding AmountPaid, StringFormat=C}" Foreground="{DynamicResource Brush.Success}" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Balance due" FontWeight="Bold" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding Balance, StringFormat=C}" FontWeight="Bold" Foreground="{DynamicResource Brush.Warning}" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
