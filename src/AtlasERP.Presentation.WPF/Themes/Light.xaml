<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Background.Window" Color="#F7F6F2" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Background.Sidebar" Color="#151A24" />
    <SolidColorBrush x:Key="Brush.Background.Hover" Color="#F1EFE9" />
    <SolidColorBrush x:Key="Brush.Background.Selected" Color="#E3F6E9" />

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#171A21" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#6B7280" />
    <SolidColorBrush x:Key="Brush.Text.OnDark" Color="#F7F6F2" />
    <SolidColorBrush x:Key="Brush.Text.OnDarkMuted" Color="#9AA4C2" />

    <Color x:Key="Color.Accent">#16A34A</Color>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#128A3E" />
    <SolidColorBrush x:Key="Brush.AccentMuted" Color="#E3F6E9" />

    <!-- Secondary "luxury" accent used sparingly: hero borders, dividers, premium badges -->
    <Color x:Key="Color.Gold">#B8860B</Color>
    <SolidColorBrush x:Key="Brush.Gold" Color="{StaticResource Color.Gold}" />
    <SolidColorBrush x:Key="Brush.GoldMuted" Color="#F5EBD3" />

    <SolidColorBrush x:Key="Brush.Border" Color="#E5E2DA" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#C7CCDA" />

    <SolidColorBrush x:Key="Brush.Success" Color="#1E9E63" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#C77E12" />
    <SolidColorBrush x:Key="Brush.Error" Color="#D6394A" />

    <Color x:Key="Color.Shadow">#33000000</Color>
    <Color x:Key="Color.ShadowSoft">#1A000000</Color>

    <LinearGradientBrush x:Key="Brush.Sidebar.Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1C2230" Offset="0" />
        <GradientStop Color="#0F131C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Accent.Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1EBB57" Offset="0" />
        <GradientStop Color="#128A3E" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Hero.Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1C2230" Offset="0" />
        <GradientStop Color="#2A3345" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Card.Sheen" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#FCFBF8" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
