<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Monochrome-first canvas: the window is a quiet neutral tone, surfaces (cards,
         the floating sidebar) sit one step lighter, and color is reserved for the accent. -->
    <SolidColorBrush x:Key="Brush.Background.Window" Color="#F4F4F2" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Background.Hover" Color="#EFEFEC" />
    <SolidColorBrush x:Key="Brush.Background.Selected" Color="#ECF3EE" />

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#18181B" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#71717A" />
    <SolidColorBrush x:Key="Brush.Text.OnDark" Color="#FAFAF9" />
    <SolidColorBrush x:Key="Brush.Text.OnDarkMuted" Color="#A8AFC4" />

    <Color x:Key="Color.Accent">#15803D</Color>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#116C31" />
    <SolidColorBrush x:Key="Brush.AccentMuted" Color="#E7F3EB" />

    <SolidColorBrush x:Key="Brush.Border" Color="#E4E4E1" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#D0D0CB" />

    <SolidColorBrush x:Key="Brush.Success" Color="#1E9E63" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#C77E12" />
    <SolidColorBrush x:Key="Brush.Error" Color="#D6394A" />

    <Color x:Key="Color.Shadow">#33000000</Color>
    <Color x:Key="Color.ShadowSoft">#1A000000</Color>

    <!-- The sidebar floats on the window canvas at the same tone as any other surface —
         barely-there gradient for a hint of depth, not a separate "dark block". -->
    <LinearGradientBrush x:Key="Brush.Sidebar.Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#FBFBFA" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Brush.Accent.Gradient" Color="{StaticResource Color.Accent}" />

    <LinearGradientBrush x:Key="Brush.Hero.Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#18181B" Offset="0" />
        <GradientStop Color="#27272A" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
