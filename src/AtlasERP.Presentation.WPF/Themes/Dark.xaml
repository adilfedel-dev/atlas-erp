<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Background.Window" Color="#12141C" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="#1B1E29" />
    <SolidColorBrush x:Key="Brush.Background.Sidebar" Color="#0D0F17" />
    <SolidColorBrush x:Key="Brush.Background.Hover" Color="#242836" />
    <SolidColorBrush x:Key="Brush.Background.Selected" Color="#1E3A2A" />

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#F3F4F8" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#9AA0AC" />
    <SolidColorBrush x:Key="Brush.Text.OnDark" Color="#F3F4F8" />
    <SolidColorBrush x:Key="Brush.Text.OnDarkMuted" Color="#8992B0" />

    <SolidColorBrush x:Key="Brush.Accent" Color="#22C55E" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#3FDA73" />
    <SolidColorBrush x:Key="Brush.AccentMuted" Color="#163223" />

    <SolidColorBrush x:Key="Brush.Border" Color="#2A2E3C" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#3C4256" />

    <SolidColorBrush x:Key="Brush.Success" Color="#3FC98A" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#E3A63E" />
    <SolidColorBrush x:Key="Brush.Error" Color="#FF6B7A" />

    <Color x:Key="Color.Shadow">#55000000</Color>

</ResourceDictionary>
