<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Monochrome-first canvas: the window is a quiet near-black tone, surfaces (cards,
         the floating sidebar) sit one step lighter, and color is reserved for the accent. -->
    <SolidColorBrush x:Key="Brush.Background.Window" Color="#0C0D0F" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="#1A1B1E" />
    <SolidColorBrush x:Key="Brush.Background.Hover" Color="#232427" />
    <SolidColorBrush x:Key="Brush.Background.Selected" Color="#173322" />

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#F4F4F5" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#A1A1AA" />
    <SolidColorBrush x:Key="Brush.Text.OnDark" Color="#F4F4F5" />
    <SolidColorBrush x:Key="Brush.Text.OnDarkMuted" Color="#8992B0" />

    <Color x:Key="Color.Accent">#22C55E</Color>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#3FDA73" />
    <SolidColorBrush x:Key="Brush.AccentMuted" Color="#153524" />

    <SolidColorBrush x:Key="Brush.Border" Color="#28292D" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#3A3C42" />

    <SolidColorBrush x:Key="Brush.Success" Color="#3FC98A" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#E3A63E" />
    <SolidColorBrush x:Key="Brush.Error" Color="#FF6B7A" />

    <Color x:Key="Color.Shadow">#77000000</Color>
    <Color x:Key="Color.ShadowSoft">#40000000</Color>

    <!-- The sidebar floats on the window canvas, one step lighter than the window
         background — not a separate dark-navy block. -->
    <LinearGradientBrush x:Key="Brush.Sidebar.Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1D1E22" Offset="0" />
        <GradientStop Color="#18191C" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Brush.Accent.Gradient" Color="{StaticResource Color.Accent}" />

    <LinearGradientBrush x:Key="Brush.Hero.Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#212226" Offset="0" />
        <GradientStop Color="#2C2D32" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
