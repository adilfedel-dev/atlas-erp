<Window x:Class="AtlasERP.Presentation.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AtlasERP.Presentation.WPF.ViewModels"
        xmlns:views="clr-namespace:AtlasERP.Presentation.WPF.Views"
        Title="AtlasERP"
        Width="1320" Height="840"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Background.Window}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeeListViewModel}">
            <views:EmployeeListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContractListViewModel}">
            <views:ContractListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PayrollRunListViewModel}">
            <views:PayrollRunListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerListViewModel}">
            <views:CustomerListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InvoiceListViewModel}">
            <views:InvoiceListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TravelExpenseListViewModel}">
            <views:TravelExpenseListView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar: replaces the native Windows chrome entirely -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding CurrentCompanyName}"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="{DynamicResource Brush.Text.Secondary}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="&#xE921;" Style="{StaticResource Button.WindowControl}" Click="Minimize_Click" />
                <Button x:Name="MaximizeRestoreButton" Content="&#xE922;" Style="{StaticResource Button.WindowControl}" Click="MaximizeRestore_Click" />
                <Button Content="&#xE8BB;" Style="{StaticResource Button.WindowControl.Close}" Click="Close_Click" />
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="228" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: a floating, inset card rather than a flush full-height block -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Sidebar.Gradient}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Margin="0,0,16,0">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource Color.Shadow}" Direction="270" ShadowDepth="4" BlurRadius="24" Opacity="0.12" />
                </Border.Effect>
                <DockPanel LastChildFill="True" Margin="0,20,0,20">

                    <!-- Brand -->
                    <StackPanel DockPanel.Dock="Top" Margin="18,0,18,20">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="10" Background="{DynamicResource Brush.Accent}" Margin="0,0,10,0">
                                <TextBlock Text="A" FontSize="16" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="AtlasERP" FontSize="15.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.Text.Primary}" />
                                <TextBlock Text="{Binding CurrentCompanyName}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.Text.Secondary}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Bottom actions -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="10,12,10,0">
                        <Border Height="1" Background="{DynamicResource Brush.Border}" Margin="6,0,6,12" />
                        <ToggleButton Style="{StaticResource Button.NavItem}"
                                      Command="{Binding NavigateToSettingsCommand}"
                                      IsChecked="{Binding IsSettingsActive, Mode=OneWay}"
                                      Content="Settings" />
                        <ToggleButton Style="{StaticResource Button.NavItem}" Command="{Binding ToggleThemeCommand}" Content="Toggle theme" />
                        <ToggleButton Style="{StaticResource Button.NavItem}" Command="{Binding LogoutCommand}" Content="Sign out" />
                    </StackPanel>

                    <!-- Nav items -->
                    <StackPanel DockPanel.Dock="Top" Margin="10,0">
                        <ToggleButton Style="{StaticResource Button.NavItem}"
                                      Command="{Binding NavigateToDashboardCommand}"
                                      IsChecked="{Binding IsDashboardActive, Mode=OneWay}"
                                      Content="Dashboard" />
                        <ToggleButton Style="{StaticResource Button.NavItem}"
                                      Command="{Binding NavigateToEmployeesCommand}"
                                      IsChecked="{Binding IsEmployeesActive, Mode=OneWay}"
                                      Content="Employees" />
                        <ToggleButton Style="{StaticResource Button.NavItem}"
                                      Command="{Binding NavigateToContractsCommand}"
                                      IsChecked="{Binding IsContractsActive, Mode=OneWay}"
                                      Content="Contracts" />
                        <ToggleButton Style="{StaticResource Button.NavItem}"
                                      Command="{Binding NavigateToPayrollCommand}"
                                      IsChecked="{Binding IsPayrollActive, Mode=OneWay}"
                                      Content="Payroll" />
                        <ToggleButton Style="{StaticResource Button.NavItem}"
                                      Command="{Binding NavigateToCustomersCommand}"
                                      IsChecked="{Binding IsCustomersActive, Mode=OneWay}"
                                      Content="Customers" />
                        <ToggleButton Style="{StaticResource Button.NavItem}"
                                      Command="{Binding NavigateToInvoicesCommand}"
                                      IsChecked="{Binding IsInvoicesActive, Mode=OneWay}"
                                      Content="Invoices" />
                        <ToggleButton Style="{StaticResource Button.NavItem}"
                                      Command="{Binding NavigateToTravelExpensesCommand}"
                                      IsChecked="{Binding IsTravelExpensesActive, Mode=OneWay}"
                                      Content="Travel Expenses" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content: each page carries its own heading, so nothing else sits above it -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
