<Window x:Class="AtlasERP.Presentation.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AtlasERP.Presentation.WPF.ViewModels"
        xmlns:views="clr-namespace:AtlasERP.Presentation.WPF.Views"
        Title="AtlasERP"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Background.Window}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeeListViewModel}">
            <views:EmployeeListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContractListViewModel}">
            <views:ContractListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PayrollRunListViewModel}">
            <views:PayrollRunListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerListViewModel}">
            <views:CustomerListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InvoiceListViewModel}">
            <views:InvoiceListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TravelExpenseListViewModel}">
            <views:TravelExpenseListView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource Brush.Sidebar.Gradient}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource Color.Shadow}" Direction="0" ShadowDepth="8" BlurRadius="20" Opacity="0.35" />
            </Border.Effect>
            <DockPanel LastChildFill="True" Margin="0,0,0,16">

                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="9" Background="{DynamicResource Brush.Accent.Gradient}" Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource Color.Accent}" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.6" />
                            </Border.Effect>
                            <TextBlock Text="A" FontSize="16" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="AtlasERP" FontSize="17" FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.Text.OnDark}" />
                            <TextBlock Text="{Binding CurrentCompanyName}"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource Brush.Text.OnDarkMuted}" />
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Margin="0,20,0,0" Opacity="0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="{DynamicResource Color.Gold}" Offset="0.5" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- Bottom actions -->
                <StackPanel DockPanel.Dock="Bottom" Margin="6,0">
                    <ToggleButton Style="{StaticResource Button.NavItem}"
                                  Command="{Binding NavigateToSettingsCommand}"
                                  IsChecked="{Binding IsSettingsActive, Mode=OneWay}"
                                  Content="⚙  Settings" />
                    <ToggleButton Style="{StaticResource Button.NavItem}" Command="{Binding ToggleThemeCommand}" Content="🌓  Toggle theme" />
                    <ToggleButton Style="{StaticResource Button.NavItem}" Command="{Binding LogoutCommand}" Content="↩  Sign out" />
                </StackPanel>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Margin="6,0">
                    <ToggleButton Style="{StaticResource Button.NavItem}"
                                  Command="{Binding NavigateToDashboardCommand}"
                                  IsChecked="{Binding IsDashboardActive, Mode=OneWay}"
                                  Content="Dashboard" />
                    <ToggleButton Style="{StaticResource Button.NavItem}"
                                  Command="{Binding NavigateToEmployeesCommand}"
                                  IsChecked="{Binding IsEmployeesActive, Mode=OneWay}"
                                  Content="Employees" />
                    <ToggleButton Style="{StaticResource Button.NavItem}"
                                  Command="{Binding NavigateToContractsCommand}"
                                  IsChecked="{Binding IsContractsActive, Mode=OneWay}"
                                  Content="Contracts" />
                    <ToggleButton Style="{StaticResource Button.NavItem}"
                                  Command="{Binding NavigateToPayrollCommand}"
                                  IsChecked="{Binding IsPayrollActive, Mode=OneWay}"
                                  Content="Payroll" />
                    <ToggleButton Style="{StaticResource Button.NavItem}"
                                  Command="{Binding NavigateToCustomersCommand}"
                                  IsChecked="{Binding IsCustomersActive, Mode=OneWay}"
                                  Content="Customers" />
                    <ToggleButton Style="{StaticResource Button.NavItem}"
                                  Command="{Binding NavigateToInvoicesCommand}"
                                  IsChecked="{Binding IsInvoicesActive, Mode=OneWay}"
                                  Content="Invoices" />
                    <ToggleButton Style="{StaticResource Button.NavItem}"
                                  Command="{Binding NavigateToTravelExpensesCommand}"
                                  IsChecked="{Binding IsTravelExpensesActive, Mode=OneWay}"
                                  Content="Travel Expenses" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.Background.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1"
                    Panel.ZIndex="1">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource Color.ShadowSoft}" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.4" />
                </Border.Effect>
                <TextBlock Text="{Binding CurrentPageTitle}"
                           Style="{StaticResource Text.Heading2}"
                           VerticalAlignment="Center"
                           Margin="28,0" />
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" Margin="0" />
        </Grid>
    </Grid>
</Window>
