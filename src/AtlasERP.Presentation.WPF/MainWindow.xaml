<Window x:Class="AtlasERP.Presentation.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AtlasERP.Presentation.WPF.ViewModels"
        xmlns:views="clr-namespace:AtlasERP.Presentation.WPF.Views"
        Title="AtlasERP"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Background.Window}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeeListViewModel}">
            <views:EmployeeListView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource Brush.Background.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <TextBlock Text="AtlasERP"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Text.Primary}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentCompanyName}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />
                    <Button Content="Toggle theme" Command="{Binding ToggleThemeCommand}" Padding="8,4" Margin="0,0,8,0" />
                    <Button Content="Sign out" Command="{Binding LogoutCommand}" Padding="8,4" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left nav -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource Brush.Background.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="8">
                <Button Content="Dashboard"
                        Command="{Binding NavigateToDashboardCommand}"
                        HorizontalContentAlignment="Left"
                        Padding="12,10"
                        Margin="0,0,0,4"
                        Background="Transparent"
                        BorderThickness="0" />
                <Button Content="Employees"
                        Command="{Binding NavigateToEmployeesCommand}"
                        HorizontalContentAlignment="Left"
                        Padding="12,10"
                        Margin="0,0,0,4"
                        Background="Transparent"
                        BorderThickness="0" />
                <!-- Future modules (Payroll, Contracts, Invoices, ...) attach nav buttons here -->
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="0">
            <ContentControl Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
